#!/bin/bash
# Post-install script for DONET

set -e

CONFIG_DIR="/etc/donet"
CONFIG_FILE="$CONFIG_DIR/config.yaml"

echo "=== DONET Network Analyzer ==="
echo ""

# Create config directory
mkdir -p "$CONFIG_DIR"

# Copy default config if it doesn't exist
if [ ! -f "$CONFIG_FILE" ]; then
    cp /usr/local/share/donet/config.example.yaml "$CONFIG_FILE"
    echo "✓ Default configuration installed to $CONFIG_FILE"
    echo "  Edit this file to customize detection settings."
else
    echo "✓ Configuration already exists at $CONFIG_FILE"
fi

# Create reports directory
mkdir -p /var/log/donet
echo "✓ Reports directory: /var/log/donet"

echo ""
echo "Installation complete!"
echo ""
echo "Quick start:"
echo "  1. List interfaces: donet --list-interfaces"
echo "  2. Start capture: sudo donet -i <interface>"
echo "  3. View help: donet --help"
echo ""
echo "Note: Packet capture requires root privileges (sudo)."
echo ""

exit 0
